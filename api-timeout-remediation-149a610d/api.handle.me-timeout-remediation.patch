+const DEFAULT_FETCH_TIMEOUT_MS = 20_000;
+
+export const getFetchTimeoutSignal = (timeoutMs = DEFAULT_FETCH_TIMEOUT_MS): AbortSignal | undefined => {
+    const timeout = (globalThis as any).AbortSignal?.timeout;
+    return typeof timeout === 'function' ? timeout(timeoutMs) : undefined;
+};
